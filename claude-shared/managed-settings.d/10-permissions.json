{
  "permissions": {
    "defaultMode": "plan",
    "skipDangerousModePermissionPrompt": true,
    "allow": [
      "Bash(date*)", "Bash(ls*)", "Bash(mkdir*)", "Bash(wc*)",
      "Bash(sort*)", "Bash(tr*)", "Bash(cat*)", "Bash(head*)",
      "Bash(tail*)", "Bash(grep*)",
      "Bash(git status*)", "Bash(git log*)", "Bash(git diff*)",
      "Bash(git tag*)", "Bash(git add*)", "Bash(git commit*)"
    ],
    "deny": [
      "Read(~/.**)", "Read(**/.env)", "Read(**/.env.*)",
      "Bash(cat ~/.**)", "Bash(cat * ~/.**)", "Bash(cat **/.env)", "Bash(cat * **/.env)", "Bash(cat **/.env.*)", "Bash(cat * **/.env.*)",
      "Bash(head ~/.**)", "Bash(head * ~/.**)", "Bash(head **/.env)", "Bash(head * **/.env)", "Bash(head **/.env.*)", "Bash(head * **/.env.*)",
      "Bash(tail ~/.**)", "Bash(tail * ~/.**)", "Bash(tail **/.env)", "Bash(tail * **/.env)", "Bash(tail **/.env.*)", "Bash(tail * **/.env.*)",
      "Bash(grep ~/.**)", "Bash(grep * ~/.**)", "Bash(grep **/.env)", "Bash(grep * **/.env)", "Bash(grep **/.env.*)", "Bash(grep * **/.env.*)",
      "Bash(* > /dev/*)",
      "Bash(rm -rf*)", "Bash(sudo *)", "Bash(chmod 777*)",
      "Bash(export ANTHROPIC_BASE_URL=*)", "Bash(export CLAUDE_BASE_URL=*)",
      "Bash(export http_proxy=*)", "Bash(export https_proxy=*)",
      "Bash(ssh *)", "Bash(scp *)", "Bash(nc *)",
      "Bash(curl * | bash)", "Bash(curl * | sh)", "Bash(curl * | python*)", "Bash(curl * | node*)", "Bash(curl * | perl*)",
      "Bash(wget * | bash)", "Bash(wget * | sh)", "Bash(wget * | python*)", "Bash(wget * | node*)", "Bash(wget * | perl*)",
      "Bash(bash <(curl*))", "Bash(eval $(curl*))", "Bash(eval \"$(curl*)\")", "Bash(source <(curl*))", "Bash(. <(curl*))"
    ]
  }
}
